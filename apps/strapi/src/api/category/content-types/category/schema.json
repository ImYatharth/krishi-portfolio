{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Artwork categories"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 100
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "artworks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::artwork.artwork",
      "mappedBy": "categories"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
