# Strapi CMS
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your-strapi-api-token

# Public URL of Strapi (for Next.js image optimization in production)
# STRAPI_PUBLIC_URL=https://cms.yourdomain.com

# Site URL (for sitemap, OG images)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ISR webhook secret (must match Strapi webhook config)
REVALIDATION_SECRET=your-secret-here
